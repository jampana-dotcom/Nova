  position:relative;
}
.dash-metric::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:2px;
  background:var(--border);
}
.dm-label{font-family:var(--font-mono);font-size:9px;letter-spacing:2px;color:var(--text3);text-transform:uppercase;margin-bottom:10px;}
.dm-val{font-family:var(--font-display);font-weight:800;font-size:28px;color:#fff;letter-spacing:-1px;line-height:1;margin-bottom:4px;}
.dm-sub{font-size:11px;color:var(--text3);}
.dm-accent{color:var(--accent);}
.dm-green{color:var(--accent3);}
.dm-amber{color:var(--amber);}

/* Market intel grid */
.dash-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px;}
.dash-panel{background:var(--ink2);border:1px solid var(--border);overflow:hidden;}
.dp-head{
  padding:14px 18px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
}
.dp-title{font-family:var(--font-display);font-weight:700;font-size:13px;color:var(--text);text-transform:uppercase;letter-spacing:.5px;}
.dp-meta{font-family:var(--font-mono);font-size:10px;color:var(--text3);}
.dp-body{padding:14px 18px;}
.market-row{
  display:flex;align-items:center;gap:12px;padding:8px 0;
  border-bottom:1px solid var(--border);font-size:12px;
}
.market-row:last-child{border-bottom:none;}
.market-name{flex:1;color:var(--text2);}
.market-mw{font-family:var(--font-mono);color:var(--text3);font-size:11px;width:60px;}
.market-bar{flex:1;height:3px;background:var(--ink3);position:relative;}
.market-bar-fill{position:absolute;top:0;left:0;height:100%;background:var(--accent);opacity:.7;}
.market-price{font-family:var(--font-mono);font-size:11px;color:var(--accent);}

/* Activity feed */
.activity-item{
