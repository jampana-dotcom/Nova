  L.control.zoom({position:'bottomright'}).addTo(simMap);

  HOTSPOTS.forEach(h=>{
    const size=h.tier==='T1'?18:h.tier==='T2'?12:8;
    const color=TC[h.tier];
    const el=document.createElement('div');
    el.style.cssText=`position:relative;width:${size}px;height:${size}px;`;
    const pulse=document.createElement('div');
    pulse.className='hs-pulse';
