.dash-welcome-title{font-family:var(--font-display);font-weight:800;font-size:28px;color:#fff;text-transform:uppercase;margin-bottom:8px;letter-spacing:-.3px;}
.dash-welcome-sub{font-size:14px;color:var(--text2);margin-bottom:24px;line-height:1.6;max-width:500px;}

/* Metric cards */
.dash-metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px;}
.dash-metric{
