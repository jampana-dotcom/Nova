<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>INFRA TERMINAL — Data Center Intelligence Platform</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow:ital,wght@0,300;0,400;0,500;0,600;1,300&family=Barlow+Condensed:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<style>
/* ═══════════════════════════════════════════════
   RESET & TOKENS
═══════════════════════════════════════════════ */
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --ink:#060912;
  --ink2:#0b1120;
  --ink3:#111a2e;
  --ink4:#18243c;
  --border:rgba(99,130,180,0.12);
  --border2:rgba(99,130,180,0.22);
  --border3:rgba(99,130,180,0.38);
  --text:#d4dff0;
  --text2:#7a93b8;
  --text3:#3d5470;
  --accent:#0ea5e9;
  --accent2:#06b6d4;
  --accent3:#10d9a0;
  --accent-glow:rgba(14,165,233,0.25);
  --accent2-glow:rgba(6,182,212,0.2);
  --accent3-glow:rgba(16,217,160,0.2);
  --amber:#f59e0b;
  --red:#ef4444;
  --font-display:'Barlow Condensed',sans-serif;
  --font-body:'Barlow',sans-serif;
  --font-mono:'JetBrains Mono',monospace;
  --shadow:0 32px 80px rgba(0,0,0,0.6),0 8px 24px rgba(0,0,0,0.4);
  --panel-shadow:0 20px 60px rgba(0,0,0,0.5),0 0 0 1px var(--border2);
}
html,body{height:100%;overflow:hidden;background:var(--ink);color:var(--text);font-family:var(--font-body);font-size:14px;}
::selection{background:rgba(14,165,233,0.3);color:var(--text);}
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--border3);border-radius:2px;}

/* ═══ VIEWS ═══ */
.view{position:fixed;inset:0;overflow:hidden;display:none;z-index:10;}
.view.active{display:flex;}

/* ═══════════════════════════════════════════════
   LANDING PAGE
═══════════════════════════════════════════════ */
#view-landing{
  flex-direction:column;
  background:var(--ink);
  overflow-y:auto;
  overflow-x:hidden;
}

/* Grid background */
#view-landing::before{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:
    linear-gradient(rgba(14,165,233,0.04) 1px,transparent 1px),
    linear-gradient(90deg,rgba(14,165,233,0.04) 1px,transparent 1px);
  background-size:60px 60px;
}
#view-landing::after{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(14,165,233,0.08) 0%,transparent 70%);
}

/* NAV */
.lnav{
  position:sticky;top:0;z-index:100;
  display:flex;align-items:center;padding:0 48px;height:60px;
  background:rgba(6,9,18,0.8);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
}
.lnav-logo{
  font-family:var(--font-display);font-weight:800;font-size:17px;letter-spacing:2px;
  color:var(--text);display:flex;align-items:center;gap:10px;text-transform:uppercase;
}
.lnav-logo-mark{
  width:28px;height:28px;border:1.5px solid var(--accent);
  display:flex;align-items:center;justify-content:center;
  position:relative;
}
.lnav-logo-mark::before{
  content:'';position:absolute;inset:3px;background:var(--accent);opacity:.15;
}
.lnav-logo-mark svg{position:relative;z-index:1;}
.lnav-right{margin-left:auto;display:flex;align-items:center;gap:10px;}
.btn-ghost{
  padding:7px 16px;background:transparent;border:1px solid var(--border2);
  color:var(--text2);font-family:var(--font-body);font-size:13px;font-weight:500;
  cursor:pointer;transition:all .15s;letter-spacing:.3px;
}
.btn-ghost:hover{border-color:var(--border3);color:var(--text);}
.btn-accent{
  padding:7px 18px;background:var(--accent);border:none;
  color:#fff;font-family:var(--font-body);font-size:13px;font-weight:600;
  cursor:pointer;transition:all .15s;letter-spacing:.3px;
}
.btn-accent:hover{background:#0284c7;box-shadow:0 0 20px var(--accent-glow);}

/* HERO */
.hero{
  position:relative;z-index:1;
  min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:80px 48px 60px;text-align:center;
}
.hero-eyebrow{
  font-family:var(--font-mono);font-size:11px;letter-spacing:4px;
  color:var(--accent);text-transform:uppercase;margin-bottom:28px;
  display:flex;align-items:center;gap:12px;
}
.hero-eyebrow::before,.hero-eyebrow::after{content:'';width:32px;height:1px;background:var(--accent);opacity:.5;}
.hero-h1{
  font-family:var(--font-display);font-weight:800;
  font-size:clamp(52px,8vw,96px);letter-spacing:-1px;line-height:.92;
  color:#fff;margin-bottom:24px;text-transform:uppercase;
}
.hero-h1 em{font-style:normal;color:var(--accent);position:relative;}
.hero-h1 em::after{
  content:'';position:absolute;bottom:-4px;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--accent),var(--accent2));
}
.hero-sub{
  font-family:var(--font-display);font-weight:400;font-size:clamp(17px,2.5vw,22px);
  color:var(--text2);margin-bottom:16px;letter-spacing:.5px;
}
.hero-desc{
  max-width:560px;font-size:15px;color:var(--text3);line-height:1.7;margin-bottom:44px;
}
.hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:80px;}
.btn-primary-lg{
  padding:14px 36px;background:var(--accent);color:#fff;border:none;
  font-family:var(--font-display);font-size:16px;font-weight:700;letter-spacing:1px;text-transform:uppercase;
  cursor:pointer;transition:all .2s;position:relative;overflow:hidden;
}
.btn-primary-lg::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.1),transparent);}
.btn-primary-lg:hover{background:#0284c7;box-shadow:0 0 40px var(--accent-glow),0 8px 24px rgba(0,0,0,.4);}
.btn-outline-lg{
  padding:14px 36px;background:transparent;color:var(--text);
  border:1px solid var(--border2);
  font-family:var(--font-display);font-size:16px;font-weight:600;letter-spacing:1px;text-transform:uppercase;
  cursor:pointer;transition:all .2s;
}
.btn-outline-lg:hover{border-color:var(--accent);color:var(--accent);}

/* Animated map canvas for hero */
#hero-map{
  width:100%;max-width:1100px;height:420px;position:relative;
  border:1px solid var(--border2);
  background:var(--ink2);
  overflow:hidden;
  margin:0 auto;
}
#hero-map::before{
  content:'';position:absolute;inset:0;z-index:2;pointer-events:none;
  background:linear-gradient(to bottom,var(--ink) 0%,transparent 15%,transparent 85%,var(--ink) 100%),
             linear-gradient(to right,var(--ink) 0%,transparent 10%,transparent 90%,var(--ink) 100%);
}
#hero-svg{width:100%;height:100%;}
.h-land{fill:#0f1d30;stroke:#162840;stroke-width:.4;}
.h-ocean{fill:#070d18;}
.h-grat{stroke:#0d1826;stroke-width:.3;fill:none;}

/* STATS BAR */
.stats-bar{
  display:flex;justify-content:center;gap:0;
  border:1px solid var(--border);
  max-width:700px;margin:0 auto 80px;
  position:relative;z-index:1;
}
.stat-item{
  flex:1;padding:20px 24px;text-align:center;
  border-right:1px solid var(--border);
}
.stat-item:last-child{border-right:none;}
.stat-num{
  font-family:var(--font-display);font-weight:800;font-size:32px;
  color:var(--accent);letter-spacing:-1px;line-height:1;margin-bottom:4px;
}
.stat-lbl{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:1px;font-weight:500;}

/* FEATURES */
.section{position:relative;z-index:1;padding:80px 48px;max-width:1200px;margin:0 auto;width:100%;}
.section-tag{
  font-family:var(--font-mono);font-size:10px;letter-spacing:3px;
  color:var(--accent3);text-transform:uppercase;margin-bottom:14px;
}
.section-h2{
  font-family:var(--font-display);font-weight:800;font-size:clamp(32px,5vw,52px);
  color:#fff;text-transform:uppercase;letter-spacing:-0.5px;margin-bottom:48px;
  line-height:1;
}
.feat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--border);}
.feat-card{
  background:var(--ink2);padding:36px 32px;
  transition:background .2s;position:relative;overflow:hidden;
}
.feat-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--accent),transparent);
  opacity:0;transition:opacity .3s;
}
.feat-card:hover{background:var(--ink3);}
.feat-card:hover::before{opacity:1;}
.feat-num{
  font-family:var(--font-mono);font-size:10px;color:var(--text3);
  letter-spacing:2px;margin-bottom:20px;
}
.feat-icon{
  width:40px;height:40px;border:1px solid var(--border2);
  display:flex;align-items:center;justify-content:center;
  font-size:18px;margin-bottom:18px;
  position:relative;
}
.feat-icon::after{
  content:'';position:absolute;inset:-1px;
  background:linear-gradient(135deg,var(--accent),transparent);
  opacity:.15;
}
.feat-title{
  font-family:var(--font-display);font-weight:700;font-size:20px;
  color:#fff;margin-bottom:10px;letter-spacing:.3px;
}
.feat-desc{font-size:14px;color:var(--text2);line-height:1.7;}

/* PRICING */
.pricing-wrap{
  display:flex;justify-content:center;padding:0 48px 100px;
  position:relative;z-index:1;
}
.pricing-card{
  width:100%;max-width:520px;
  border:1px solid var(--border2);
  background:var(--ink2);
  position:relative;overflow:hidden;
}
.pricing-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--accent),var(--accent2),var(--accent3));
}
.pricing-inner{padding:44px;}
.pricing-tag{
  font-family:var(--font-mono);font-size:10px;letter-spacing:3px;
  color:var(--accent);text-transform:uppercase;margin-bottom:10px;
}
.pricing-name{
  font-family:var(--font-display);font-weight:800;font-size:28px;
  color:#fff;text-transform:uppercase;letter-spacing:1px;margin-bottom:28px;
}
.pricing-price{
  display:flex;align-items:baseline;gap:6px;margin-bottom:8px;
}
.pricing-price-num{
  font-family:var(--font-display);font-weight:800;font-size:64px;
  color:#fff;letter-spacing:-2px;line-height:1;
}
.pricing-price-meta{font-size:14px;color:var(--text2);}
.pricing-desc{font-size:13px;color:var(--text3);margin-bottom:32px;line-height:1.6;}
.pricing-features{list-style:none;margin-bottom:36px;display:flex;flex-direction:column;gap:10px;}
.pricing-features li{
  display:flex;align-items:center;gap:12px;font-size:14px;color:var(--text2);
}
.pricing-features li::before{
  content:'';width:6px;height:6px;border-radius:50%;
  background:var(--accent3);flex-shrink:0;
  box-shadow:0 0 8px var(--accent3-glow);
}
.btn-pricing{
  width:100%;padding:16px;background:var(--accent);color:#fff;border:none;
  font-family:var(--font-display);font-size:16px;font-weight:700;letter-spacing:2px;text-transform:uppercase;
  cursor:pointer;transition:all .2s;position:relative;overflow:hidden;
}
.btn-pricing::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.12),transparent);}
.btn-pricing:hover{background:#0284c7;box-shadow:0 0 40px var(--accent-glow);}

/* FOOTER */
.lfoot{
  position:relative;z-index:1;
  border-top:1px solid var(--border);
  padding:28px 48px;
  display:flex;align-items:center;justify-content:space-between;
}
.lfoot-copy{font-size:12px;color:var(--text3);font-family:var(--font-mono);}

/* ═══════════════════════════════════════════════
   AUTH PAGES
═══════════════════════════════════════════════ */
#view-auth{
  background:var(--ink);
  align-items:center;justify-content:center;
}
#view-auth::before{
  content:'';position:fixed;inset:0;pointer-events:none;
  background-image:linear-gradient(rgba(14,165,233,0.035) 1px,transparent 1px),linear-gradient(90deg,rgba(14,165,233,0.035) 1px,transparent 1px);
  background-size:60px 60px;
}
.auth-wrap{
  position:relative;z-index:1;
  width:100%;max-width:420px;padding:20px;
}
.auth-logo{
  text-align:center;margin-bottom:36px;
}
.auth-logo-mark{
  width:44px;height:44px;border:1.5px solid var(--accent);
  display:flex;align-items:center;justify-content:center;
  margin:0 auto 12px;position:relative;
}
.auth-logo-mark::before{content:'';position:absolute;inset:4px;background:var(--accent);opacity:.12;}
.auth-logo-name{
  font-family:var(--font-display);font-weight:800;font-size:15px;letter-spacing:3px;
  color:var(--text);text-transform:uppercase;
}
.auth-card{
  background:var(--ink2);border:1px solid var(--border2);
  padding:36px 32px;position:relative;
}
.auth-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--accent),transparent);
}
.auth-title{
  font-family:var(--font-display);font-weight:700;font-size:22px;
  color:#fff;margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px;
}
.auth-sub{font-size:13px;color:var(--text3);margin-bottom:28px;line-height:1.5;}
.form-group{margin-bottom:16px;}
.form-label{
  display:block;font-size:11px;font-weight:600;color:var(--text2);
  text-transform:uppercase;letter-spacing:1px;margin-bottom:7px;
  font-family:var(--font-mono);
}
.form-input{
  width:100%;padding:11px 14px;
  background:var(--ink3);border:1px solid var(--border2);
  color:var(--text);font-family:var(--font-body);font-size:14px;
  outline:none;transition:border-color .15s;
}
.form-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-glow);}
.form-input::placeholder{color:var(--text3);}
.form-error{font-size:12px;color:var(--red);margin-top:5px;display:none;}
.form-error.show{display:block;}
.btn-form{
  width:100%;padding:12px;background:var(--accent);color:#fff;border:none;
  font-family:var(--font-display);font-size:15px;font-weight:700;letter-spacing:2px;text-transform:uppercase;
  cursor:pointer;transition:all .15s;margin-top:8px;
}
.btn-form:hover{background:#0284c7;box-shadow:0 0 24px var(--accent-glow);}
.btn-form:disabled{opacity:.5;cursor:not-allowed;}
.auth-link{text-align:center;margin-top:20px;font-size:13px;color:var(--text3);}
.auth-link a{color:var(--accent);text-decoration:none;font-weight:500;}
.auth-link a:hover{text-decoration:underline;}
.auth-divider{display:flex;align-items:center;gap:12px;margin:20px 0;color:var(--text3);font-size:12px;}
.auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:var(--border);}

/* ═══════════════════════════════════════════════
   SUBSCRIPTION PAGE
═══════════════════════════════════════════════ */
#view-subscribe{
  background:var(--ink);
  align-items:center;justify-content:center;
  flex-direction:column;
}
#view-subscribe::before{
  content:'';position:fixed;inset:0;pointer-events:none;
  background-image:linear-gradient(rgba(14,165,233,0.035) 1px,transparent 1px),linear-gradient(90deg,rgba(14,165,233,0.035) 1px,transparent 1px);
  background-size:60px 60px;
}
.sub-wrap{position:relative;z-index:1;width:100%;max-width:520px;padding:20px;}
.sub-header{text-align:center;margin-bottom:36px;}
.sub-eyebrow{font-family:var(--font-mono);font-size:10px;letter-spacing:3px;color:var(--accent);text-transform:uppercase;margin-bottom:10px;}
.sub-title{font-family:var(--font-display);font-weight:800;font-size:28px;color:#fff;text-transform:uppercase;margin-bottom:8px;letter-spacing:-.3px;}
.sub-desc{font-size:14px;color:var(--text2);line-height:1.6;}
.sub-card{background:var(--ink2);border:1px solid var(--border2);position:relative;overflow:hidden;}
.sub-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent2),var(--accent3));}
.sub-card-inner{padding:36px;}
.sub-price-row{display:flex;align-items:baseline;gap:6px;margin-bottom:24px;}
.sub-price-big{font-family:var(--font-display);font-weight:800;font-size:56px;color:#fff;letter-spacing:-2px;line-height:1;}
.sub-price-mo{font-size:14px;color:var(--text2);}
.sub-features{list-style:none;margin-bottom:28px;display:flex;flex-direction:column;gap:9px;}
.sub-features li{display:flex;align-items:center;gap:10px;font-size:14px;color:var(--text2);}
.sub-features li svg{color:var(--accent3);flex-shrink:0;}
.sub-card-foot{border-top:1px solid var(--border);padding:20px 36px;background:rgba(14,165,233,0.03);}
.sub-guarantee{font-size:12px;color:var(--text3);display:flex;align-items:center;gap:8px;}

/* Payment form */
.payment-section{margin-top:20px;}
.pay-label{font-size:11px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;font-family:var(--font-mono);}
.card-mock{
  background:var(--ink3);border:1px solid var(--border2);
  padding:12px 14px;margin-bottom:12px;
  display:flex;align-items:center;gap:10px;
  font-family:var(--font-mono);font-size:13px;color:var(--text2);
}
.card-mock-icon{font-size:16px;}
.btn-pay{
  width:100%;padding:14px;background:var(--accent);color:#fff;border:none;
  font-family:var(--font-display);font-size:15px;font-weight:700;letter-spacing:2px;text-transform:uppercase;
  cursor:pointer;transition:all .2s;position:relative;overflow:hidden;
}
.btn-pay::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.1),transparent);}
.btn-pay:hover{background:#0284c7;box-shadow:0 0 32px var(--accent-glow);}
.sub-back{
  margin-top:14px;text-align:center;font-size:13px;color:var(--text3);
}
.sub-back a{color:var(--accent);text-decoration:none;cursor:pointer;}

/* ═══════════════════════════════════════════════
   DASHBOARD
═══════════════════════════════════════════════ */
#view-dashboard{flex-direction:row;}

/* SIDEBAR */
.sidebar{
  width:220px;flex-shrink:0;
  background:var(--ink2);
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;
  height:100%;
}
.sb-logo{
  padding:20px 20px 16px;
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:10px;
}
.sb-logo-mark{
  width:30px;height:30px;border:1.5px solid var(--accent);
  display:flex;align-items:center;justify-content:center;
  position:relative;flex-shrink:0;
}
.sb-logo-mark::before{content:'';position:absolute;inset:3px;background:var(--accent);opacity:.12;}
.sb-logo-name{
  font-family:var(--font-display);font-weight:800;font-size:13px;letter-spacing:2px;
  color:var(--text);text-transform:uppercase;line-height:1.2;
}
.sb-logo-sub{font-size:9px;color:var(--accent);letter-spacing:1.5px;font-family:var(--font-mono);}
.sb-nav{flex:1;padding:12px 8px;overflow-y:auto;}
.sb-section-label{
  font-size:9px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:1.5px;
  padding:8px 12px 6px;font-family:var(--font-mono);
}
.sb-item{
  display:flex;align-items:center;gap:10px;
  padding:9px 12px;border-radius:0;cursor:pointer;
  transition:all .12s;color:var(--text2);font-size:13px;font-weight:500;
  position:relative;
}
.sb-item:hover{background:rgba(255,255,255,.04);color:var(--text);}
.sb-item.active{color:var(--accent);background:rgba(14,165,233,0.08);}
.sb-item.active::before{
  content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:var(--accent);
}
.sb-item svg{flex-shrink:0;opacity:.7;}
.sb-item.active svg{opacity:1;}
.sb-badge{
  margin-left:auto;font-size:9px;font-family:var(--font-mono);
  background:var(--accent);color:#fff;padding:2px 6px;
}
.sb-foot{border-top:1px solid var(--border);padding:14px 12px;}
.sb-user{display:flex;align-items:center;gap:10px;}
.sb-avatar{
  width:30px;height:30px;background:var(--accent);
  display:flex;align-items:center;justify-content:center;
