.fp-title{font-family:var(--font-display);font-weight:700;font-size:13px;color:var(--text);text-transform:uppercase;letter-spacing:.5px;}
.fp-sub{font-size:11px;color:var(--text3);margin-top:1px;}
.fp-body{padding:12px 14px;overflow-y:auto;}

/* Search panel */
#fp-search{top:62px;left:14px;width:276px;}
