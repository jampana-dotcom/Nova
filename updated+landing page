  simCount: 0,
  bestRoi: null,
  bestMw: null,
};

function showView(id) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById('view-' + id).classList.add('active');

  if (id === 'landing') initHeroMap();
  if (id === 'simulator') { initSimMap(); }
  if (id === 'dashboard') updateDashboard();
}

function showAuth(section) {
  showView('auth');
  showAuthSection(section);
}

function showAuthSection(s) {
  ['login','signup','forgot','reset-sent'].forEach(x => {
    const el = document.getElementById('auth-'+x);
    if(el) el.style.display = 'none';
  });
  const target = document.getElementById('auth-'+s);
  if(target) target.style.display = 'block';
}

// ═══════════════════════════════════════════════
// AUTH LOGIC (simulated)
// ═══════════════════════════════════════════════

// Simulated user store
const USERS = {};

function doSignup() {
  const name = document.getElementById('signup-name').value.trim();
  const email = document.getElementById('signup-email').value.trim();
  const pw = document.getElementById('signup-password').value;
  const err = document.getElementById('signup-error');
  if (!name || !email || pw.length < 6) { err.classList.add('show'); return; }
  err.classList.remove('show');
  USERS[email] = { name, email, pw };
  APP.user = { name, email };
  APP.subscribed = false;
  showView('subscribe');
}

function doLogin() {
  const email = document.getElementById('login-email').value.trim();
  const pw = document.getElementById('login-password').value;
  const err = document.getElementById('login-error');

  // Demo: any valid email/pw combo works, or pre-seeded users
  if (!email || !pw) { err.classList.add('show'); return; }
  err.classList.remove('show');

  const user = USERS[email];
  if (user && user.pw !== pw) { err.classList.add('show'); return; }

  APP.user = user || { name: email.split('@')[0].replace(/\./g,' ').replace(/\b\w/g,c=>c.toUpperCase()), email };
  APP.subscribed = true; // returning users assumed subscribed for demo
  updateDashboard();
  showView('dashboard');
}

function doForgot() {
  showAuthSection('reset-sent');
}

function doLogout() {
  APP.user = null;
  APP.subscribed = false;
  showView('landing');
}

function doSubscribe() {
  APP.subscribed = true;
  updateDashboard();
  showView('dashboard');
}

function updateDashboard() {
  if (!APP.user) return;
  const initials = APP.user.name.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
  document.getElementById('sb-avatar').textContent = initials;
  document.getElementById('sb-user-name').textContent = APP.user.name;
  document.getElementById('welcome-msg').textContent = 'Welcome back, ' + APP.user.name.split(' ')[0] + '.';
  document.getElementById('acc-name').value = APP.user.name;
  document.getElementById('acc-email').value = APP.user.email;
  // Metrics
  document.getElementById('dm-sims').textContent = APP.simCount;
  document.getElementById('dm-mw').textContent = APP.bestMw ? APP.bestMw + ' MW' : '—';
  document.getElementById('dm-roi').textContent = APP.bestRoi ? APP.bestRoi.toFixed(1) + '%' : '—';
}

function launchSim() {
  if (!APP.subscribed) { showView('subscribe'); return; }
  APP.simCount++;
  updateDashboard();
  showView('simulator');
}

function setDashTab(el, tab) {
  document.querySelectorAll('.sb-item').forEach(i=>i.classList.remove('active'));
  el.classList.add('active');
  ['overview','saved','markets','billing','account'].forEach(t => {
    const p = document.getElementById('panel-'+t);
