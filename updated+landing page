.activity-text{font-size:12px;color:var(--text2);line-height:1.5;}
.activity-time{font-family:var(--font-mono);font-size:10px;color:var(--text3);margin-top:3px;}

/* LAUNCH button */
.launch-card{
  background:var(--ink2);border:1px solid var(--border2);
  padding:32px;position:relative;overflow:hidden;
  display:flex;align-items:center;gap:28px;
}
.launch-card::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 60% 80% at 0% 50%,rgba(14,165,233,0.06),transparent);
}
.launch-card-text{position:relative;z-index:1;flex:1;}
.launch-card-title{font-family:var(--font-display);font-weight:800;font-size:22px;color:#fff;text-transform:uppercase;margin-bottom:6px;letter-spacing:-.3px;}
.launch-card-sub{font-size:13px;color:var(--text2);line-height:1.6;}
.btn-launch{
  flex-shrink:0;padding:14px 32px;background:var(--accent);color:#fff;border:none;
  font-family:var(--font-display);font-size:15px;font-weight:700;letter-spacing:2px;text-transform:uppercase;
  cursor:pointer;transition:all .2s;position:relative;z-index:1;white-space:nowrap;
}
.btn-launch::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.12),transparent);}
.btn-launch:hover{background:#0284c7;box-shadow:0 0 32px var(--accent-glow),0 8px 24px rgba(0,0,0,.4);}

