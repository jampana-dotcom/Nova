.spill-green{background:rgba(16,217,160,.1);color:var(--accent3);border:1px solid rgba(16,217,160,.2);}
.spill-red{background:rgba(239,68,68,.1);color:var(--red);border:1px solid rgba(239,68,68,.2);}
.spill-amber{background:rgba(245,158,11,.1);color:var(--amber);border:1px solid rgba(245,158,11,.2);}
.btn-back-dash{
