  showView('landing');
  initHeroMap();

  // CSS animation for hero hotspots
  const style = document.createElement('style');
  style.textContent = `@keyframes hspulse{0%{transform:scale(1);opacity:.7;}100%{transform:scale(2.8);opacity:0;}}`;
  document.head.appendChild(style);
});
</script>
