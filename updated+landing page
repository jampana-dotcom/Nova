function buildFacility(){
  const f=calcF();if(!f)return;
  simMarkDone(2);goSimStep(3);
  document.getElementById('fsub').textContent=`${fmtN(f.nRacks)} racks · ${f.mw}MW · ${S.chip.name} — drag to orbit`;
  setTimeout(()=>{if(!R)initThree();buildScene(f);},80);
}
function resetCam(){theta=.55;phi=1.05;camR=110;moveCam();}
function toggleWF(){wf=!wf;SC.traverse(o=>{if(o.isMesh&&o.material)o.material.wireframe=wf;});}

// ═══════════════════════════════════════════════
// SIM STEP FLOW
// ═══════════════════════════════════════════════

function goSimStep(n){
  S.step=n;
  for(let i=1;i<=4;i++)document.getElementById('ss'+i).classList.toggle('active',i===n);
  document.getElementById('fp-search').classList.toggle('hidden',n!==1||!!S.loc);
  document.getElementById('fp-site').classList.toggle('hidden',!S.loc||n>2);
  document.getElementById('fp-config').classList.toggle('hidden',n<2);
  document.getElementById('fp-3d').classList.toggle('hidden',n<3);
  document.getElementById('fp-fin').classList.toggle('hidden',n<2);
  if(n>=2){simMarkDone(1);const f=calcF();if(f)renderFinance(f);}
  if(n>=3&&!R){setTimeout(()=>{initThree();const f=calcF();if(f)buildScene(f);},80);}
  if(n>=4)simMarkDone(3);
}
function simMarkDone(n){document.getElementById('ss'+n)?.classList.add('done');}
function ctab(tab,el){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tabpanel').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');document.getElementById('tp-'+tab).classList.add('active');
}

