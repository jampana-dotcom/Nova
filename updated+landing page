.sbox input{flex:1;border:none;background:transparent;font-family:var(--font-body);font-size:13px;color:var(--text);outline:none;}
.sbox input::placeholder{color:var(--text3);}
.sec-lbl{font-family:var(--font-mono);font-size:9px;letter-spacing:2px;color:var(--text3);text-transform:uppercase;margin-bottom:7px;}
.rlist{display:flex;flex-direction:column;gap:1px;max-height:400px;overflow-y:auto;}
.ri{display:flex;align-items:center;gap:9px;padding:7px 8px;cursor:pointer;transition:background .1s;}
.ri:hover{background:rgba(255,255,255,.04);}
.ri.active{background:rgba(14,165,233,.08);}
.rdot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
.rname{font-size:12px;font-weight:500;flex:1;color:var(--text);}
.rmeta{font-size:10px;color:var(--text3);font-family:var(--font-mono);}

/* Site panel */
#fp-site{top:62px;left:14px;width:276px;max-height:calc(100vh-80px);}
.site-hero{height:72px;position:relative;overflow:hidden;display:flex;align-items:flex-end;padding:10px 14px;}
.site-hero-bg{position:absolute;inset:0;background:linear-gradient(135deg,#071530,#1a3a6e);}
.site-hero-grid{position:absolute;inset:0;opacity:.07;background-image:linear-gradient(rgba(255,255,255,1) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,1) 1px,transparent 1px);background-size:16px 16px;}
.site-nm{font-family:var(--font-display);font-weight:700;font-size:15px;color:#fff;position:relative;z-index:1;}
.site-co{font-size:10px;color:rgba(255,255,255,.4);font-family:var(--font-mono);position:relative;z-index:1;margin-top:1px;}
.sgrid{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-bottom:11px;}
.sc{background:rgba(255,255,255,.03);padding:8px 10px;border:1px solid var(--border);}
.sclbl{font-size:9px;color:var(--text3);font-weight:600;text-transform:uppercase;letter-spacing:.5px;margin-bottom:2px;font-family:var(--font-mono);}
.scval{font-size:13px;font-weight:700;font-family:var(--font-mono);}
.scval.bl{color:var(--accent);}.scval.gr{color:var(--accent3);}.scval.am{color:var(--amber);}.scval.rd{color:var(--red);}

/* Config panel */
#fp-config{top:62px;right:14px;width:300px;max-height:calc(100vh-80px);}
.tabbar{display:flex;border-bottom:1px solid var(--border);margin:0 -14px 11px;padding:0 14px;}
.tab{padding:7px 9px;font-size:11px;font-weight:600;color:var(--text3);cursor:pointer;border-bottom:2px solid transparent;transition:all .13s;margin-bottom:-1px;text-transform:uppercase;letter-spacing:.5px;font-family:var(--font-mono);}
.tab:hover{color:var(--text2);}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);}
.tabpanel{display:none;}.tabpanel.active{display:block;}
.cgrid{display:grid;grid-template-columns:1fr 1fr;gap:5px;margin-bottom:11px;}
.cc{border:1px solid var(--border2);padding:9px;cursor:pointer;transition:all .13s;background:rgba(255,255,255,.02);position:relative;}
