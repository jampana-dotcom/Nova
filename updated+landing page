let R,SC,CAM,drag=false,lmx=0,lmy=0,theta=.55,phi=1.05,camR=110,wf=false;
const meshes=[];

function initThree(){
  const canvas=document.getElementById('tcanvas');
  const wrap=document.getElementById('tcwrap');
  R=new THREE.WebGLRenderer({canvas,antialias:true});
  R.setPixelRatio(Math.min(devicePixelRatio,2));
  R.shadowMap.enabled=true;
  R.setSize(wrap.clientWidth,wrap.clientHeight);
  SC=new THREE.Scene();SC.background=new THREE.Color(0x040810);SC.fog=new THREE.FogExp2(0x040810,.008);
  CAM=new THREE.PerspectiveCamera(42,wrap.clientWidth/wrap.clientHeight,.1,1000);moveCam();
  SC.add(new THREE.AmbientLight(0x1a2d4a,.9));
  const dl=new THREE.DirectionalLight(0x7aaac8,1.4);dl.position.set(60,80,50);dl.castShadow=true;SC.add(dl);
  SC.add(Object.assign(new THREE.PointLight(0x0ea5e9,3,90),{position:new THREE.Vector3(0,22,0)}));
  SC.add(Object.assign(new THREE.PointLight(0x10d9a0,1.5,60),{position:new THREE.Vector3(20,10,-20)}));
  const gnd=new THREE.Mesh(new THREE.PlaneGeometry(400,400),new THREE.MeshLambertMaterial({color:0x060c18}));
  gnd.rotation.x=-Math.PI/2;gnd.receiveShadow=true;SC.add(gnd);
  SC.add(new THREE.GridHelper(400,60,0x0f2040,0x090f1e));
  wrap.addEventListener('mousedown',e=>{drag=true;lmx=e.clientX;lmy=e.clientY;});
  window.addEventListener('mouseup',()=>drag=false);
  window.addEventListener('mousemove',e=>{if(!drag)return;theta-=(e.clientX-lmx)*.008;phi=Math.max(.25,Math.min(1.45,phi-(e.clientY-lmy)*.005));lmx=e.clientX;lmy=e.clientY;moveCam();});
  wrap.addEventListener('wheel',e=>{camR=Math.max(35,Math.min(280,camR+e.deltaY*.12));moveCam();});
  (function anim(){requestAnimationFrame(anim);R.render(SC,CAM);})();
}

function moveCam(){if(!CAM)return;CAM.position.set(camR*Math.sin(phi)*Math.sin(theta),camR*Math.cos(phi),camR*Math.sin(phi)*Math.cos(theta));CAM.lookAt(0,4,0);}

function buildScene(f){
  meshes.forEach(m=>SC.remove(m));meshes.length=0;
  const nH=Math.max(1,Math.min(8,Math.ceil(f.nRacks/1000)));
  const rpH=Math.ceil(f.nRacks/nH);
  const hW=26,hD=56,hH=9,gap=7,totW=nH*(hW+gap)-gap,ox=-totW/2;
  const mk=(geo,col,cast=true)=>{const m=new THREE.Mesh(geo,new THREE.MeshLambertMaterial({color:col}));if(cast)m.castShadow=true;m.receiveShadow=true;return m;};
  for(let i=0;i<nH;i++){
    const hx=ox+i*(hW+gap)+hW/2,g=new THREE.Group();
    const body=mk(new THREE.BoxGeometry(hW,hH,hD),0x0d2040);body.position.set(0,hH/2,0);g.add(body);
    const roof=mk(new THREE.BoxGeometry(hW+.6,.6,hD+.6),0x08182e);roof.position.set(0,hH+.3,0);g.add(roof);
    const win=mk(new THREE.BoxGeometry(hW-.4,.7,hD-.4),0x0e2d50,false);win.position.set(0,hH*.62,0);g.add(win);
    const cols=Math.min(7,Math.ceil(Math.sqrt(rpH))),rows=Math.min(7,Math.ceil(rpH/cols));
    for(let r=0;r<rows;r++)for(let c=0;c<cols;c++){
      const rk=mk(new THREE.BoxGeometry(1.1,6.2,1.2),0x0a2a5c);
      rk.position.set(-(cols*1.55)/2+c*1.55+.775,3.1,-(rows*1.85)/2+r*1.85+.925);g.add(rk);
      const led=new THREE.Mesh(new THREE.BoxGeometry(.055,6,.04),new THREE.MeshBasicMaterial({color:0x00a8e8}));
      led.position.set(-(cols*1.55)/2+c*1.55+1.325,3.1,-(rows*1.85)/2+r*1.85+.925+.62);g.add(led);
    }
    g.position.set(hx,0,0);SC.add(g);meshes.push(g);
  }
  const cc=Math.max(2,Math.ceil(nH*1.6));
  for(let i=0;i<cc;i++){
    const cx=ox+(i/(cc-1||1))*totW;
    const tw=mk(new THREE.BoxGeometry(7,6,5),0x08261a);tw.position.set(cx,3,hD/2+5);SC.add(tw);meshes.push(tw);
    const fan=mk(new THREE.CylinderGeometry(2,2,.5,10),0x051410);fan.position.set(cx,6.25,hD/2+5);SC.add(fan);meshes.push(fan);
  }
  const sub=mk(new THREE.BoxGeometry(20,8,12),0x1e1000);sub.position.set(ox-18,4,0);SC.add(sub);meshes.push(sub);
  for(let i=0;i<4;i++){const t=mk(new THREE.CylinderGeometry(1.2,1.3,4,8),0x2c1800);t.position.set(ox-18+(i-1.5)*4.5,4.5,-7.5);SC.add(t);meshes.push(t);}
  const adm=mk(new THREE.BoxGeometry(18,7,14),0x0c1620);adm.position.set(totW/2-ox+14,3.5,-hD/2-9);SC.add(adm);meshes.push(adm);
  const rd=new THREE.Mesh(new THREE.PlaneGeometry(totW+80,6),new THREE.MeshLambertMaterial({color:0x050912}));rd.rotation.x=-Math.PI/2;rd.position.set(0,.02,hD/2+13);SC.add(rd);meshes.push(rd);
  document.getElementById('cvleg').innerHTML=`
    <div class="lgi"><div class="lgd" style="background:#0d2040"></div><span class="lgl">Server Halls</span></div>
    <div class="lgi"><div class="lgd" style="background:#08261a"></div><span class="lgl">Cooling</span></div>
    <div class="lgi"><div class="lgd" style="background:#1e1000"></div><span class="lgl">Substation</span></div>
    <div class="lgi"><div class="lgd" style="background:#0c1620"></div><span class="lgl">Admin</span></div>`;
  renderFacStats(f);
}

