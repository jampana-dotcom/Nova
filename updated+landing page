function calcF(){
  const loc=S.loc;if(!loc)return null;
  const{chip,mw,util,redun,gpuPrice,coloRate,revMix}=S;
  const totalKW=mw*1000,facKW=totalKW*loc.pue;
  const nChips=Math.floor(totalKW/chip.pwrKW);
  const nRacks=Math.ceil(nChips/chip.gpr);
  const acres=Math.max(1,Math.ceil(mw*.5+nRacks*.008));
  const rdm={1:1.15,2:1.30,3:1.45}[redun];
  const cChip=nChips*chip.cost,cBuild=mw*loc.constructionCostPerMW*loc.laborMult*rdm;
  const cLand=acres*loc.landCostPerAcre,cPwr=mw*1600000*rdm,cCool=mw*900000;
  const cNet=nRacks*18000,cMisc=(cBuild+cChip)*.08;
  const capex=cChip+cBuild+cLand+cPwr+cCool+cNet+cMisc;
  const oPwr=facKW*8760*loc.powerCostKwh,oLab=nRacks*600*loc.laborMult;
  const oWat=mw*1200*loc.waterCostM3,oNet=nRacks*2200,oMnt=capex*.025,oIns=capex*.008;
  const opex=oPwr+oLab+oWat+oNet+oMnt+oIns;
  const gRev=nChips*8760*util*gpuPrice,cRev=nRacks*coloRate*12;
  const rev=revMix==='gpu'?gRev:revMix==='colo'?cRev:gRev*.6+cRev*.4;
  const ebitda=rev-opex,depr=capex/7,ebit=ebitda-depr;
  const tax=Math.max(0,ebit*loc.taxRate),ni=ebit-tax;
  const roi=capex>0?(ni/capex)*100:0;
  const pb=ni>0?capex/ni:null;
  const margin=rev>0?ebitda/rev*100:0;
  return{nChips,nRacks,acres,capex,opex,rev,ebitda,ni,roi,pb,margin,
    yr5:Math.max(0,ni*5-capex),yr10:Math.max(0,ni*10-capex),mw};
}

function recalc(){
  const f=calcF();if(!f)return;
  renderFinance(f);updateSimTB(f);
  // Update app metrics
  if(f.roi>0&&(!APP.bestRoi||f.roi>APP.bestRoi))APP.bestRoi=f.roi;
  if(!APP.bestMw||f.mw>APP.bestMw)APP.bestMw=f.mw;
  if(S.step>=3)renderFacStats(f);
}

function fmt(n){
  if(n===null||isNaN(n))return'—';
  const a=Math.abs(n),s=n<0?'-':'';
  if(a>=1e9)return s+'$'+(a/1e9).toFixed(2)+'B';
  if(a>=1e6)return s+'$'+(a/1e6).toFixed(1)+'M';
  if(a>=1e3)return s+'$'+(a/1e3).toFixed(0)+'K';
  return s+'$'+a.toFixed(0);
}
function fmtN(n){return n>=1e6?(n/1e6).toFixed(1)+'M':n>=1e3?(n/1e3).toFixed(1)+'K':n.toLocaleString();}

function renderFinance(f){
  const p=f.ni>0;
  const rc=f.roi>15?'var(--accent3)':f.roi>5?'var(--accent)':f.roi>0?'var(--amber)':'var(--red)';
  document.getElementById('fingrid').innerHTML=`
    <div class="fm"><div class="fml">Total CAPEX</div><div class="fmv" style="color:var(--amber)">${fmt(f.capex)}</div><div class="fms">${fmt(f.capex/f.mw)}/MW</div></div>
    <div class="fm"><div class="fml">Annual Revenue</div><div class="fmv" style="color:var(--accent3)">${fmt(f.rev)}</div><div class="fms">${fmt(f.rev/12)}/mo</div></div>
    <div class="fm"><div class="fml">Net Income/yr</div><div class="fmv" style="color:${p?'var(--accent3)':'var(--red)'}">${fmt(f.ni)}</div><div class="fms">EBITDA ${f.margin.toFixed(0)}%</div></div>
    <div class="fm"><div class="fml">ROI (Unlevered)</div><div class="fmv" style="color:${rc}">${f.roi.toFixed(1)}%</div><div class="fms">${f.pb?f.pb.toFixed(1)+'yr payback':'Negative'}</div></div>
    <div class="fm"><div class="fml">10-yr Profit</div><div class="fmv" style="color:${f.yr10>0?'var(--accent3)':'var(--red)'}">${fmt(f.yr10)}</div><div class="fms">5yr: ${fmt(f.yr5)}</div></div>`;
  document.getElementById('finsub').textContent=`${fmtN(f.nChips)} chips · ${fmtN(f.nRacks)} racks · ${f.mw} MW`;
  document.getElementById('finpills').innerHTML=`
    <span class="spill ${p?'spill-green':'spill-red'}">${p?'PROFITABLE':'LOSS-MAKING'}</span>
    <span class="spill spill-blue">${f.pb?f.pb.toFixed(1)+'yr payback':'No payback'}</span>`;
}

