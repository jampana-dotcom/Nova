function makeCustomLoc(lat,lng){
  let pc=.07,land=80000,build=8500000,tax=.25,pue=1.45,lab=.8,ren=25,grid=99.7,conn='Tier 3',perm=16;
  if(lng>-10&&lng<40&&lat>35){pc=.085;land=200000;build=9500000;tax=.22;pue=1.3;lab=1.1;ren=45;grid=99.9;conn='Tier 2';}
  else if(lng>-130&&lng<-60&&lat>25&&lat<55){pc=.06;land=150000;build=9000000;tax=.21;pue=1.38;lab=1.0;ren=30;grid=99.9;conn='Tier 2';}
  else if(lng>100&&lat>-10&&lat<40){pc=.09;land=200000;build=9000000;tax=.20;pue=1.5;lab=.7;ren=20;grid=99.7;conn='Tier 2';}
  if(Math.abs(lat)>55){pue=Math.max(1.15,pue-.2);pc=Math.max(.03,pc-.025);ren=Math.min(95,ren+30);}
  const nm=lng>-10&&lng<40&&lat>35?'European Site':lng>-130&&lng<-60&&lat>25&&lat<55?'N. American Site':lng>100&&lat>-10&&lat<40?'Asia-Pacific Site':'Custom Site';
  return{id:'custom',name:nm,lat,lng,powerCostKwh:+pc.toFixed(3),landCostPerAcre:land,constructionCostPerMW:build,taxRate:tax,pue,laborMult:lab,waterCostM3:3,renewablesPct:ren,gridReliability:grid,permittingMonths:perm,connectivity:conn,tier:'T3',existingMW:0,dcCount:0};
}

