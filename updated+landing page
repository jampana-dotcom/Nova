.fstl{font-size:9px;color:var(--text3);margin-top:1px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:.5px;}

/* Finance panel */
#fp-fin{bottom:14px;left:50%;transform:translateX(-50%);width:900px;max-width:calc(100vw-28px);}
